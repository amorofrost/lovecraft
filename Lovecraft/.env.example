USE_AZURE_STORAGE=true
AZURE_STORAGE_CONNECTION_STRING=
JWT_SECRET_KEY=

# Telegram Login Widget + Lovecraft.TelegramBot (optional)
# Get a bot from @BotFather; link your site domain with /setdomain for the widget.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Alternative (standard .NET config binding) — either style works:
# Telegram__BotToken=
# Telegram__BotUsername=